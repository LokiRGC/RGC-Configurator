<Window x:Class="RGC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:models="clr-namespace:RGC.Models"
        Title="RGC - Конфигуратор DayZ Server" Height="800" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="ScrollBar" x:Key="DarkScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="False">
                                <Track.Thumb>
                                    <Thumb BorderThickness="0" MinHeight="20">
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="{DynamicResource ButtonBgBrush}" CornerRadius="3" Margin="0,2"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Thumb">
                                                                    <Border Background="{DynamicResource TextMutedBrush}" CornerRadius="3" Margin="0,2"/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>
        <Style TargetType="TextBlock" x:Key="SectionTitle">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style TargetType="TextBox" x:Key="Tb">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource InputTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{DynamicResource InputCaretBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style TargetType="CheckBox" x:Key="Cb">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style TargetType="TabControl" x:Key="TabControlStyle">
            <Setter Property="Background" Value="{DynamicResource WindowInnerBgBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TabItem" x:Key="TabStyle">
            <Setter Property="Background" Value="{DynamicResource TabBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TabInactiveTextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Background="{DynamicResource TabBgBrush}" BorderThickness="0" Padding="14,8" Margin="0,0,2,0" CornerRadius="8,8,0,0">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource TabActiveBgBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TabActiveTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource WindowBgBrush}" CornerRadius="16" MouseDown="Window_MouseDown">
        <Grid Margin="16,16,16,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="←" Width="36" Height="28" Background="Transparent"
                        Foreground="{DynamicResource TextMutedBrush}" BorderThickness="0" Cursor="Hand" FontSize="16"
                        Click="BackToProjects_Click" ToolTip="Назад к проектам" Margin="0,0,8,0"/>
                <TextBlock Grid.Column="1" x:Name="ProjectTitleText" Text="RGC DayZ Configurator"
                           FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="⚙" Width="28" Height="28" Background="Transparent" Foreground="{DynamicResource TextMutedBrush}"
                            BorderThickness="0" Cursor="Hand" FontSize="14" Click="Settings_Click"
                            ToolTip="Настройки приложения"/>
                    <Button Content="─" Width="28" Height="28" Background="Transparent" Foreground="{DynamicResource TextMutedBrush}"
                            BorderThickness="0" Cursor="Hand" FontSize="14" Click="Minimize_Click"/>
                    <Button Content="✕" Width="28" Height="28" Background="Transparent" Foreground="{DynamicResource TextMutedBrush}"
                            BorderThickness="0" Cursor="Hand" FontSize="14" Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- Middle: config area -->
            <Grid Grid.Row="1" Margin="0,4,0,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Server folder selector -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,0,6">
                    <TextBlock x:Name="ServerPathLabel" Text="Папка сервера:" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="ServerPathBox" Style="{StaticResource Tb}" ToolTip="Путь к папке с установленным DayZ сервером" Width="350" Margin="0,0,6,0" IsReadOnly="True"/>
                    <Button Content="Обзор" x:Name="BrowseFolderBtn" Click="BrowseFolder_Click" Background="{DynamicResource ButtonBgBrush}" Foreground="{DynamicResource ButtonTextBrush}" BorderThickness="0" Padding="10,6" FontSize="12" Cursor="Hand" ToolTip="Выбрать папку сервера"/>
                </StackPanel>

                <!-- Tabs -->
                <TabControl x:Name="MainTabControl" Grid.Row="1" Style="{StaticResource TabControlStyle}" VerticalContentAlignment="Stretch">
                    <!-- TAB 1: Основные -->
                    <TabItem x:Name="Tab1" Header="Основные" Style="{StaticResource TabStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                            <StackPanel>
                                <TextBlock x:Name="CfgMainTitle" Text="Основные настройки сервера" Style="{StaticResource SectionTitle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="Название сервера" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="HostnameBox" Style="{StaticResource Tb}" ToolTip="Название сервера, отображаемое в списке серверов"/>
                                        <TextBlock Text="Пароль для входа" Style="{StaticResource FieldLabel}"/>
                                        <DockPanel Margin="0,0,0,10">
                                            <Button Content="🎲" Width="28" Height="28" Background="Transparent"
                                                    Foreground="{DynamicResource TextMutedBrush}" BorderThickness="0"
                                                    Cursor="Hand" FontSize="12" DockPanel.Dock="Right"
                                                    ToolTip="Сгенерировать пароль" Click="GeneratePassword_Click"
                                                    Tag="PasswordBox"/>
                                            <TextBox x:Name="PasswordBox" Style="{StaticResource Tb}"
                                                     ToolTip="Пароль для входа на сервер (оставьте пустым, если не требуется)"
                                                     Margin="0,0,6,0"/>
                                        </DockPanel>
                                        <TextBlock Text="Пароль администратора" Style="{StaticResource FieldLabel}"/>
                                        <DockPanel Margin="0,0,0,10">
                                            <Button Content="🎲" Width="28" Height="28" Background="Transparent"
                                                    Foreground="{DynamicResource TextMutedBrush}" BorderThickness="0"
                                                    Cursor="Hand" FontSize="12" DockPanel.Dock="Right"
                                                    ToolTip="Сгенерировать пароль" Click="GeneratePassword_Click"
                                                    Tag="AdminPasswordBox"/>
                                            <TextBox x:Name="AdminPasswordBox" Style="{StaticResource Tb}"
                                                     ToolTip="Пароль для получения прав администратора на сервере"
                                                     Margin="0,0,6,0"/>
                                        </DockPanel>
                                        <TextBlock Text="Максимум игроков" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="MaxPlayersBox" Style="{StaticResource Tb}" ToolTip="Максимальное количество игроков на сервере (рекомендуется 60)"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <DockPanel>
                                            <Button Content="🎲" Width="28" Height="28" Background="Transparent"
                                                    Foreground="{DynamicResource TextMutedBrush}" BorderThickness="0"
                                                    Cursor="Hand" FontSize="12" DockPanel.Dock="Right"
                                                    VerticalAlignment="Top" Margin="0,2,0,0"
                                                    ToolTip="Сгенерировать описание" Click="GenerateDescription_Click"/>
                                            <StackPanel>
                                                <TextBlock Text="Описание сервера" Style="{StaticResource FieldLabel}"/>
                                                <TextBox x:Name="DescriptionBox" Style="{StaticResource Tb}"
                                                         ToolTip="Описание сервера, отображаемое в списке серверов"
                                                         Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                                                         Margin="0,0,6,0"/>
                                            </StackPanel>
                                        </DockPanel>
                                        <TextBlock Text="Shard ID (6 символов)" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="ShardIdBox" Style="{StaticResource Tb}" ToolTip="Идентификатор шарда (до 6 символов) для разделения игроков" MaxLength="6"/>
                                        <TextBlock Text="Миссия (template)" Style="{StaticResource FieldLabel}"/>
                                        <CheckBox x:Name="WhitelistCheck" Content="Включить whitelist" Style="{StaticResource Cb}" ToolTip="Включить список допуска — только одобренные игроки смогут зайти"/>
                                        <ComboBox x:Name="MissionCombo" IsEditable="True" ToolTip="Выберите шаблон миссии (карту) для сервера"
                                                  FontSize="13">
                                            <ComboBox.Resources>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#313244"/>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#cdd6f4"/>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#45475a"/>
                                                <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>
                                            </ComboBox.Resources>
                                            <ComboBox.ItemContainerStyle>
                                                <Style TargetType="{x:Type ComboBoxItem}">
                                                    <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsHighlighted" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource ButtonBgBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ComboBox.ItemContainerStyle>
                                            <ComboBox.Template>
                                                <ControlTemplate TargetType="{x:Type ComboBox}">
                                                    <Grid>
                                                        <Border x:Name="Border" Background="{DynamicResource InputBgBrush}" CornerRadius="6">
                                                            <Grid>
                                                                <TextBox x:Name="PART_EditableTextBox"
                                                                         Text="{TemplateBinding Text}"
                                                                         Background="Transparent"
                                                                         Foreground="{DynamicResource InputTextBrush}"
                                                                         BorderThickness="0"
                                                                         Padding="8,6"
                                                                         CaretBrush="{DynamicResource InputCaretBrush}"
                                                                         VerticalAlignment="Center"
                                                                         IsReadOnly="{TemplateBinding IsReadOnly}"/>
                                                                <ToggleButton x:Name="ToggleButton"
                                                                              Background="Transparent"
                                                                              HorizontalAlignment="Right"
                                                                              Width="24"
                                                                              Cursor="Hand"
                                                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource Mode=TemplatedParent}}">
                                                                    <Path Data="M0,0 L6,6 L12,0"
                                                                          Stroke="{DynamicResource TextMutedBrush}"
                                                                          StrokeThickness="1.5"
                                                                          Fill="Transparent"
                                                                          VerticalAlignment="Center"
                                                                          HorizontalAlignment="Center"/>
                                                                </ToggleButton>
                                                            </Grid>
                                                        </Border>
                                                        <Popup x:Name="Popup" Placement="Bottom"
                                                               IsOpen="{TemplateBinding IsDropDownOpen}"
                                                               PlacementTarget="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}}"
                                                               AllowsTransparency="True"
                                                               Focusable="False"
                                                               PopupAnimation="Slide">
                                                            <Border Background="{DynamicResource InputBgBrush}" CornerRadius="6" MaxHeight="200">
                                                                <ScrollViewer>
                                                                    <ItemsPresenter/>
                                                                </ScrollViewer>
                                                            </Border>
                                                        </Popup>
                                                    </Grid>
                                                </ControlTemplate>
                                            </ComboBox.Template>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- TAB 2: Мир -->
                    <TabItem Header="Мир" Style="{StaticResource TabStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="Игровой процесс и мир" Style="{StaticResource SectionTitle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <CheckBox x:Name="Disable3rdPersonCheck" Content="Отключить вид от 3-го лица" Style="{StaticResource Cb}" ToolTip="Запретить игрокам использовать вид от третьего лица"/>
                                        <CheckBox x:Name="DisableCrosshairCheck" Content="Отключить прицел" Style="{StaticResource Cb}" ToolTip="Убрать прицел с экрана у всех игроков"/>
                                        <CheckBox x:Name="DisablePersonalLightCheck" Content="Отключить личный фонарик" Style="{StaticResource Cb}" ToolTip="Отключить личный фонарик у игроков"/>
                                        <TextBlock Text="Освещение (0 - яркая ночь, 1 - тёмная)" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="LightingBox" Style="{StaticResource Tb}" ToolTip="Уровень освещения: 0 — яркая ночь, 1 — тёмная ночь, 2+ — ещё темнее"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock Text="Начальное время (SystemTime или YYYY/MM/DD/HH/MM)" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="ServerTimeBox" Style="{StaticResource Tb}" ToolTip="Начальное время на сервере: SystemTime или YYYY/MM/DD/HH/MM"/>
                                        <TextBlock Text="Ускорение времени (0-24)" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="TimeAccelBox" Style="{StaticResource Tb}" ToolTip="Ускорение течения времени: 0 — без ускорения, 24 — 1 час реального = 1 день в игре"/>
                                        <TextBlock Text="Ускорение ночи (0.1-64)" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="NightAccelBox" Style="{StaticResource Tb}" ToolTip="Ускорение ночного времени (0.1–64)"/>
                                        <CheckBox x:Name="TimePersistentCheck" Content="Сохранять время" Style="{StaticResource Cb}" ToolTip="Сохранять игровое время после перезапуска сервера"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- TAB 3: Сеть -->
                    <TabItem Header="Сеть" Style="{StaticResource TabStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="Сетевые настройки" Style="{StaticResource SectionTitle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="Порт сервера" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="PortBox" Style="{StaticResource Tb}" ToolTip="Порт для подключения к серверу (по умолчанию 2302)"/>
                                        <TextBlock Text="Проверка подписей (2)" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="VerifySigBox" Style="{StaticResource Tb}" ToolTip="Проверка подписей модов (0 — выкл, 1 — для клиентов, 2 — для всех)"/>
                                        <CheckBox x:Name="ForceSameBuildCheck" Content="Требовать ту же сборку" Style="{StaticResource Cb}" ToolTip="Требовать у игроков ту же версию сборки клиента"/>
                                        <CheckBox x:Name="DisableVonCheck" Content="Отключить голосовой чат" Style="{StaticResource Cb}" ToolTip="Полностью отключить голосовой чат"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock Text="Качество голоса (0-30)" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="VonQualityBox" Style="{StaticResource Tb}" ToolTip="Качество голосового чата (0–30, чем выше, тем лучше)"/>
                                        <TextBlock Text="Одновременных входов" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="LoginConcurrentBox" Style="{StaticResource Tb}" ToolTip="Сколько игроков могут входить одновременно"/>
                                        <TextBlock Text="Макс. очередь входа" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="LoginMaxBox" Style="{StaticResource Tb}" ToolTip="Максимальный размер очереди входа"/>
                                        <TextBlock Text="Instance ID" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="InstanceIdBox" Style="{StaticResource Tb}" ToolTip="ID игрового экземпляра (должен быть уникальным для каждого сервера)"/>
                                        <TextBlock Text="RCon пароль" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="RConPassBox" Style="{StaticResource Tb}" ToolTip="Пароль для удалённого управления сервером через RCon"/>
                                    </StackPanel>
                                </Grid>
                                <CheckBox x:Name="StorageAutoFixCheck" Content="Авто-исправление файлов сохранений" Style="{StaticResource Cb}" ToolTip="Автоматически исправлять повреждённые файлы сохранений"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- TAB 4: Моды -->
                    <TabItem Header="Моды" Style="{StaticResource TabStyle}">
                        <Grid Margin="16,12,16,8" VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <Button Content="🔍 Сканировать моды" x:Name="ScanModsBtn" Click="ScanMods_Click"
                                        Background="{DynamicResource ButtonBgBrush}" Foreground="{DynamicResource ButtonTextBrush}" BorderThickness="0"
                                        Padding="14,6" FontSize="12" Cursor="Hand" ToolTip="Просканировать папку сервера и найти все установленные моды"/>
                            </StackPanel>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" VerticalAlignment="Stretch">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Клиентские моды (-mod=)" Style="{StaticResource SectionTitle}" FontSize="13"/>
                                <Border Grid.Row="1" Background="{DynamicResource WindowInnerBgBrush}" CornerRadius="8" Padding="8" Margin="0,0,0,8">
                                    <Grid>
                                        <TextBox x:Name="NewModBox" Style="{StaticResource Tb}" ToolTip="Введите название папки мода (с @ в начале) для клиентской части" Margin="0"
                                                 Text="Введите название мода..."
                                                 GotKeyboardFocus="RemoveModPlaceholder"
                                                 LostKeyboardFocus="SetModPlaceholder"/>
                                        <Button Content="+" Click="AddMod_Click"
                                                Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource AccentTextBrush}"
                                                BorderThickness="0" FontSize="16" FontWeight="Bold"
                                                Width="30" Height="28" Cursor="Hand"
                                                HorizontalAlignment="Right" ToolTip="Добавить мод в список клиентских модов"/>
                                    </Grid>
                                </Border>
                                <ListBox Grid.Row="2" x:Name="ModListBox" Background="{DynamicResource ListBgBrush}" BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.Resources>
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>
                                    </ListBox.Resources>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource BorderBgBrush}" CornerRadius="6" Padding="10,8" Margin="0,2">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Image Grid.Column="0" Source="pack://application:,,,/mod_icon.png" Width="16" Height="16"
                                                                   Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Version}" FontSize="11"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding Name}" Foreground="{DynamicResource TextBrush}" FontSize="12" VerticalAlignment="Center"/>
                                                            <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                                                                <Button Click="OpenWorkshopFromMod_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Width="28" Height="24" ToolTip="Открыть страницу мода в Steam Workshop">
                                                                    <TextBlock Text="🌐" FontSize="13"/>
                                                                </Button>
                                                                <Button Click="DeleteModFolder_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Width="28" Height="24" ToolTip="Удалить папку мода">
                                                                    <Image Source="pack://application:,,,/trash_icon.png" Width="16" Height="16"/>
                                                                </Button>
                                                                <Button Click="OpenModFolder_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Width="28" Height="24" ToolTip="Открыть папку мода">
                                                                    <Image Source="pack://application:,,,/folder_icon.png" Width="16" Height="16"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                </ListBox>
                                <Button Grid.Row="3" Content="Удалить выбранный" Click="RemoveMod_Click"
                                        Background="{DynamicResource ButtonBgBrush}" Foreground="{DynamicResource ButtonTextBrush}" BorderThickness="0"
                                        Padding="8,4" FontSize="11" Cursor="Hand" Margin="0,6,0,0"
                                        HorizontalAlignment="Left" ToolTip="Убрать выбранный мод из списка (папка не удаляется)"/>
                            </Grid>
                            <Grid Grid.Column="2" VerticalAlignment="Stretch">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Серверные моды (-servermod=)" Style="{StaticResource SectionTitle}" FontSize="13"/>
                                <Border Grid.Row="1" Background="{DynamicResource WindowInnerBgBrush}" CornerRadius="8" Padding="8" Margin="0,0,0,8">
                                    <Grid>
                                        <TextBox x:Name="NewServerModBox" Style="{StaticResource Tb}" ToolTip="Введите название папки серверного мода (например, @ServerModMyMod)" Margin="0"
                                                 Text="Введите название мода..."
                                                 GotKeyboardFocus="RemoveSrvModPlaceholder"
                                                 LostKeyboardFocus="SetSrvModPlaceholder"/>
                                        <Button Content="+" Click="AddServerMod_Click"
                                                Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource AccentTextBrush}"
                                                BorderThickness="0" FontSize="16" FontWeight="Bold"
                                                Width="30" Height="28" Cursor="Hand"
                                                HorizontalAlignment="Right" ToolTip="Добавить мод в список серверных модов"/>
                                    </Grid>
                                </Border>
                                <ListBox Grid.Row="2" x:Name="ServerModListBox" Background="{DynamicResource ListBgBrush}" BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.Resources>
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>
                                    </ListBox.Resources>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource BorderBgBrush}" CornerRadius="6" Padding="10,8" Margin="0,2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Image Grid.Column="0" Source="pack://application:,,,/mod_icon.png" Width="16" Height="16"
                                                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Version}" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Name}" Foreground="{DynamicResource TextBrush}" FontSize="12" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                                                        <Button Click="OpenWorkshopFromMod_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Width="28" Height="24" ToolTip="Открыть страницу мода в Steam Workshop">
                                                            <TextBlock Text="🌐" FontSize="13"/>
                                                        </Button>
                                                        <Button Click="DeleteModFolder_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Width="28" Height="24" ToolTip="Удалить папку мода">
                                                            <Image Source="pack://application:,,,/trash_icon.png" Width="16" Height="16"/>
                                                        </Button>
                                                        <Button Click="OpenServerModFolder_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Width="28" Height="24" ToolTip="Открыть папку мода">
                                                            <Image Source="pack://application:,,,/folder_icon.png" Width="16" Height="16"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Button Grid.Row="3" Content="Удалить выбранный" Click="RemoveServerMod_Click"
                                        Background="{DynamicResource ButtonBgBrush}" Foreground="{DynamicResource ButtonTextBrush}" BorderThickness="0"
                                        Padding="8,4" FontSize="11" Cursor="Hand" Margin="0,6,0,0"
                                        HorizontalAlignment="Left" ToolTip="Убрать выбранный серверный мод из списка"/>
                            </Grid>
                        </Grid>
                        </Grid>
                    </TabItem>

                    <!-- TAB 5: Batch -->
                    <TabItem Header="Batch" Style="{StaticResource TabStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="Настройки Start.bat" Style="{StaticResource SectionTitle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="Имя в заголовке окна" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="BatchNameBox" Style="{StaticResource Tb}" ToolTip="Имя окна консоли сервера при запуске через Start.bat"/>
                                        <TextBlock Text="Порт в batch" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="BatchPortBox" Style="{StaticResource Tb}" ToolTip="Порт для конфигурации Start.bat (обычно совпадает с портом сервера)"/>
                                        <TextBlock Text="Ядер CPU" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="CpuBox" Style="{StaticResource Tb}" ToolTip="Количество ядер процессора, выделяемых серверу"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock Text="Имя файла конфига" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="ConfigFileBox" Style="{StaticResource Tb}" ToolTip="Имя файла конфигурации сервера (по умолчанию serverDZ.cfg)"/>
                                        <TextBlock Text="Интервал рестарта (сек)" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="RestartBox" Style="{StaticResource Tb}" ToolTip="Интервал автоматического рестарта сервера в секундах (0 — без рестарта)"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- TAB 6: Config модов -->
                    <TabItem Header="Config модов" Style="{StaticResource TabStyle}">
                        <Grid Margin="16,12,16,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,6">
                                <Button Content="🔄 Обновить" Click="RefreshProfiles_Click"
                                        Background="{DynamicResource ButtonBgBrush}" Foreground="{DynamicResource ButtonTextBrush}" BorderThickness="0"
                                        Padding="10,4" FontSize="12" Cursor="Hand" Margin="0,0,8,0" ToolTip="Обновить список профилей конфигурации модов"/>
                                <Button x:Name="SaveProfileConfigBtn"
                                Content="💾 Сохранить" Click="SaveConfigFile_Click"
                                        Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource AccentTextBrush}" BorderThickness="0"
                                        Padding="10,4" FontSize="12" Cursor="Hand" IsEnabled="False" ToolTip="Сохранить изменения в выбранном файле конфигурации"/>
                            </StackPanel>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="250"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="{DynamicResource WindowBgBrush}" CornerRadius="8" Padding="0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0" Background="{DynamicResource TitleBgBrush}" CornerRadius="8,8,0,0" Padding="10,6">
                                            <TextBlock Text="Profiles" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                        </Border>
                                        <TreeView x:Name="ProfilesTree" Grid.Row="1"
                                                  Background="Transparent" BorderThickness="0"
                                                  Foreground="{DynamicResource TextBrush}" FontSize="12"
                                                  SelectedItemChanged="ProfilesTree_SelectedItemChanged">
                                            <TreeView.Resources>
                                                <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>
                                                <HierarchicalDataTemplate DataType="{x:Type models:TreeItem}"
                                                    ItemsSource="{Binding Children}">
                                                    <StackPanel Orientation="Horizontal" Margin="2,1">
                                                        <Image Source="{Binding IconSrc}" Width="16" Height="16"
                                                               Visibility="{Binding ImageIconVisibility}"
                                                               Margin="0,0,4,0"/>
                                                        <TextBlock Text="📄" FontSize="12"
                                                                   Visibility="{Binding FileIconVisibility}"
                                                                   Margin="0,0,4,0"/>
                                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextBrush}" FontSize="12"/>
                                                    </StackPanel>
                                                </HierarchicalDataTemplate>
                                            </TreeView.Resources>
                                        </TreeView>
                                    </Grid>
                                </Border>

                                <GridSplitter Grid.Column="1" Width="4" Background="{DynamicResource SplitterBrush}"
                                              VerticalAlignment="Stretch" HorizontalAlignment="Center"/>

                                <Border Grid.Column="2" Background="{DynamicResource WindowBgBrush}" CornerRadius="8" Padding="0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0" Background="{DynamicResource TitleBgBrush}" CornerRadius="8,8,0,0" Padding="10,6">
                                            <TextBlock x:Name="ProfileFilePathText" Text="Выберите файл"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                        </Border>

                                        <avalonedit:TextEditor x:Name="ModConfigEditor"
                                                               Grid.Row="1"
                                                               Background="{DynamicResource WindowBgBrush}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontFamily="Consolas"
                                                               FontSize="13"
                                                               ShowLineNumbers="True"
                                                               SyntaxHighlighting="XML"
                                                               Visibility="Collapsed">
                                            <avalonedit:TextEditor.Resources>
                                                <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>
                                            </avalonedit:TextEditor.Resources>
                                        </avalonedit:TextEditor>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <!-- TAB 7: Запуск сервера -->
                    <TabItem Header="Запуск" Style="{StaticResource TabStyle}">
                        <Grid Margin="16,12,16,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                <Button x:Name="StartServerBtn" Content="▶ Запустить" Click="StartServer_Click"
                                        Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource AccentTextBrush}" BorderThickness="0"
                                        Padding="12,6" FontSize="12" FontWeight="Bold" Cursor="Hand" ToolTip="Запустить DayZ сервер с текущими настройками"/>
                                <Button x:Name="StopServerBtn" Content="⏹ Остановить" Click="StopServer_Click"
                                        Background="{DynamicResource DangerBrush}" Foreground="{DynamicResource AccentTextBrush}" BorderThickness="0"
                                        Padding="12,6" FontSize="12" FontWeight="Bold" Cursor="Hand"
                                        Margin="8,0,0,0" IsEnabled="False" ToolTip="Остановить работающий сервер"/>
                                <Button Content="🗑 Очистить лог" x:Name="ClearLogBtn" Click="ClearLog_Click"
                                        Background="{DynamicResource ButtonBgBrush}" Foreground="{DynamicResource ButtonTextBrush}" BorderThickness="0"
                                        Padding="10,4" FontSize="11" Cursor="Hand" Margin="8,0,0,0" ToolTip="Очистить содержимое консоли сервера"/>
                                <Button Content="⚙ Установить сервер" x:Name="InstallServerBtn" Click="InstallServer_Click"
                                        Background="{DynamicResource SuccessBrush}" Foreground="{DynamicResource AccentTextBrush}" BorderThickness="0"
                                        Padding="10,4" FontSize="11" Cursor="Hand" Margin="8,0,0,0"
                                        FontWeight="Bold" ToolTip="Установить или обновить DayZ сервер через SteamCMD"/>
                                <Button Content="🔍 Версия" x:Name="CheckVersionBtn" Click="CheckVersion_Click"
                                        Background="{DynamicResource ButtonBgBrush}" Foreground="{DynamicResource ButtonTextBrush}" BorderThickness="0"
                                        Padding="10,4" FontSize="11" Cursor="Hand" Margin="8,0,0,0"
                                        ToolTip="Проверить установленную версию DayZ и сравнить с актуальной в Steam"/>
                            </StackPanel>

                            <Border Grid.Row="1" Background="{DynamicResource WindowBgBrush}" CornerRadius="8" Padding="0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="{DynamicResource TitleBgBrush}" CornerRadius="8,8,0,0" Padding="10,6">
                                        <TextBlock Text="Консоль сервера" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                    </Border>
                                    <Grid x:Name="ProgressPanel" Grid.Row="1" Visibility="Collapsed" Margin="10,6,10,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ProgressBar x:Name="DownloadProgressBar" Grid.Column="0"
                                                     Height="6" Minimum="0" Maximum="100"
                                                     Foreground="{DynamicResource AccentBrush}"
                                                     Background="{DynamicResource InputBgBrush}"
                                                     BorderThickness="0"/>
                                        <TextBlock x:Name="ProgressPercentText" Grid.Column="1"
                                                   Text="0%" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="10" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                    <ListBox x:Name="LogListBox" Grid.Row="2" Background="Transparent"
                                             BorderThickness="0" Foreground="{DynamicResource TextBrush}" FontSize="11"
                                             FontFamily="Consolas" VirtualizingPanel.ScrollUnit="Pixel"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                        <ListBox.Resources>
                                            <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>
                                        </ListBox.Resources>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Padding" Value="8,1"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Text}" Foreground="{Binding Brush}"
                                                           FontSize="11" TextWrapping="NoWrap"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- TAB 8: RCon -->
                    <TabItem Header="RCon" Style="{StaticResource TabStyle}">
                        <Grid Margin="16,12,16,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Хост:" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox x:Name="RConHostBox" Grid.Column="1" Text="127.0.0.1"
                                             Foreground="{DynamicResource InputTextBrush}" Background="{DynamicResource InputBgBrush}" BorderThickness="0"
                                             Padding="6,5" FontSize="11" ToolTip="IP-адрес или домен сервера для подключения RCon"/>
                                    <TextBlock Grid.Column="2" Text="Порт:" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                               VerticalAlignment="Center" Margin="8,0,6,0"/>
                                    <TextBox x:Name="RConPortBox" Grid.Column="3" Text="2402"
                                             Foreground="{DynamicResource InputTextBrush}" Background="{DynamicResource InputBgBrush}" BorderThickness="0"
                                             Padding="6,5" FontSize="11" ToolTip="Порт для RCon подключения (по умолчанию 2302)"/>
                                    <Button x:Name="RConConnectBtn" Grid.Column="4" Content="🔗 Подключиться"
                                            Click="RConConnect_Click"
                                            Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource AccentTextBrush}" BorderThickness="0"
                                            Padding="10,4" FontSize="11" Cursor="Hand" FontWeight="Bold"
                                            Margin="8,0,0,0" ToolTip="Подключиться к серверу через RCon"/>
                                    <Button x:Name="RConDisconnectBtn" Grid.Column="4" Content="🔌 Отключиться"
                                            Click="RConDisconnect_Click"
                                            Background="{DynamicResource DangerBrush}" Foreground="{DynamicResource AccentTextBrush}" BorderThickness="0"
                                            Padding="10,4" FontSize="11" Cursor="Hand" FontWeight="Bold"
                                            Margin="8,0,0,0" Visibility="Collapsed" ToolTip="Отключиться от сервера"/>
                                </Grid>

                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="RConCmdBox" Grid.Column="0"
                                             Foreground="{DynamicResource InputTextBrush}" Background="{DynamicResource InputBgBrush}" BorderThickness="0"
                                             Padding="10,6" FontSize="12" KeyDown="RConCmdBox_KeyDown" ToolTip="Введите команду для отправки на сервер"/>
                                    <Button Grid.Column="1" Content="Отправить" x:Name="RConSendBtn" Click="RConSend_Click"
                                            Background="{DynamicResource ButtonBgBrush}" Foreground="{DynamicResource ButtonTextBrush}" BorderThickness="0"
                                            Padding="12,4" FontSize="11" Cursor="Hand" Margin="6,0,0,0" ToolTip="Отправить команду на сервер"/>
                                </Grid>
                            </StackPanel>

                            <Border Grid.Row="1" Background="{DynamicResource WindowBgBrush}" CornerRadius="8" Padding="0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="{DynamicResource TitleBgBrush}" CornerRadius="8,8,0,0" Padding="10,6">
                                        <TextBlock Text="RCon консоль" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                    </Border>
                                    <ListBox x:Name="RConLogBox" Grid.Row="1" Background="Transparent"
                                             BorderThickness="0" Foreground="{DynamicResource TextBrush}" FontSize="11"
                                             FontFamily="Consolas">
                                        <ListBox.Resources>
                                            <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>
                                        </ListBox.Resources>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Padding" Value="8,2"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Text}" Foreground="{Binding Brush}"
                                                           FontSize="11" TextWrapping="NoWrap"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- TAB 9: Статистика -->
                    <TabItem Header="Статистика" Style="{StaticResource TabStyle}">
                        <Grid Margin="16,12,16,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="🔄 Обновить статистику" Click="RefreshStats_Click"
                                        Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource AccentTextBrush}" BorderThickness="0"
                                        Padding="10,4" FontSize="11" Cursor="Hand" FontWeight="Bold" ToolTip="Обновить статистику игроков из папки profiles"/>
                                <TextBlock x:Name="StatsSummary" Text="" Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11" VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>

                            <Border Grid.Row="1" Background="{DynamicResource WindowBgBrush}" CornerRadius="8" Padding="0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="{DynamicResource TitleBgBrush}" CornerRadius="8,8,0,0" Padding="10,6">
                                        <TextBlock Text="Игроки по времени игры" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                    </Border>
                                    <ListBox x:Name="StatsListBox" Grid.Row="1" Background="Transparent"
                                             BorderThickness="0" Foreground="{DynamicResource TextBrush}" FontSize="12">
                                        <ListBox.Resources>
                                            <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>
                                        </ListBox.Resources>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Padding" Value="8,4"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource ItemBgBrush}" CornerRadius="4" Padding="8,4" Margin="0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                                                   FontSize="12" Margin="0,0,8,0"/>
                                                        <TextBlock Grid.Column="1" Foreground="{DynamicResource TextBrush}" FontSize="12">
                                                            <Run Text="{Binding Name}"/>
                                                            <Run Text="—" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/>
                                                            <Run Text="{Binding DisplayTime}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                                        </TextBlock>
                                                        <TextBlock Grid.Column="2" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                                                                   Text="{Binding DisplayLastSeen}"
                                                                   VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>

            <!-- Bottom bar -->
            <Border Grid.Row="2" Background="{DynamicResource WindowInnerBgBrush}" CornerRadius="8" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" x:Name="StatusBar" Text="Готов к работе" Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="📥 Импорт" x:Name="ImportConfigBtn" Click="ImportConfig_Click" Background="{DynamicResource ButtonBgBrush}" Foreground="{DynamicResource ButtonTextBrush}" BorderThickness="0" Padding="10,6" FontSize="11" Cursor="Hand" Margin="0,0,6,0" ToolTip="Загрузить конфигурацию из файла"/>
                        <Button Content="📤 Экспорт" x:Name="ExportConfigBtn" Click="ExportConfig_Click" Background="{DynamicResource ButtonBgBrush}" Foreground="{DynamicResource ButtonTextBrush}" BorderThickness="0" Padding="10,6" FontSize="11" Cursor="Hand" Margin="0,0,8,0" ToolTip="Сохранить конфигурацию в файл"/>
                        <Button Content="Загрузить конфиг" x:Name="LoadConfigBtn" Click="LoadConfig_Click" Background="{DynamicResource ButtonBgBrush}" Foreground="{DynamicResource ButtonTextBrush}" BorderThickness="0" Padding="12,6" FontSize="12" Cursor="Hand" Margin="0,0,8,0" ToolTip="Загрузить конфигурацию сервера из папки"/>
                        <Button Content="Сохранить" x:Name="SaveConfigBtn" Click="SaveConfig_Click" Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource AccentTextBrush}" BorderThickness="0" Padding="16,6" FontSize="12" FontWeight="Bold" Cursor="Hand" ToolTip="Сохранить текущую конфигурацию в файлы сервера"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Grid.Row="2" Text="v1.0.0" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,4"/>
        </Grid>
    </Border>
</Window>
