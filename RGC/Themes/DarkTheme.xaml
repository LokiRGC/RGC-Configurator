<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Main window -->
    <Color x:Key="WindowBgColor">#1e1e2e</Color>
    <Color x:Key="WindowInnerBgColor">#181825</Color>
    <Color x:Key="TitleBgColor">#181825</Color>

    <!-- Text -->
    <Color x:Key="TextColor">#cdd6f4</Color>
    <Color x:Key="TextSecondaryColor">#a6adc8</Color>
    <Color x:Key="TextMutedColor">#6c7086</Color>
    <Color x:Key="TextPlaceholderColor">#6c7086</Color>

    <!-- Input -->
    <Color x:Key="InputBgColor">#313244</Color>
    <Color x:Key="InputTextColor">#cdd6f4</Color>
    <Color x:Key="InputCaretColor">#89b4fa</Color>
    <Color x:Key="InputBorderColor">Transparent</Color>

    <!-- Accent -->
    <Color x:Key="AccentColor">#89b4fa</Color>
    <Color x:Key="AccentTextColor">#1e1e2e</Color>
    <Color x:Key="ButtonBgColor">#45475a</Color>
    <Color x:Key="ButtonTextColor">#cdd6f4</Color>

    <!-- Status colors -->
    <Color x:Key="SuccessColor">#a6e3a1</Color>
    <Color x:Key="DangerColor">#f38ba8</Color>
    <Color x:Key="WarningColor">#f9e2af</Color>
    <Color x:Key="InfoColor">#cba6f7</Color>

    <!-- ScrollBar -->
    <Color x:Key="ScrollThumbColor">#45475a</Color>
    <Color x:Key="ScrollThumbHoverColor">#585b70</Color>

    <!-- Tab -->
    <Color x:Key="TabBgColor">#1e1e2e</Color>
    <Color x:Key="TabActiveBgColor">#181825</Color>
    <Color x:Key="TabActiveTextColor">#89b4fa</Color>
    <Color x:Key="TabInactiveTextColor">#6c7086</Color>

    <!-- List / Item -->
    <Color x:Key="ItemBgColor">#313244</Color>
    <Color x:Key="ListBgColor">#181825</Color>
    <Color x:Key="BorderBgColor">#1e1e2e</Color>

    <!-- Separator -->
    <Color x:Key="SplitterColor">#313244</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="WindowBgBrush" Color="{StaticResource WindowBgColor}"/>
    <SolidColorBrush x:Key="WindowInnerBgBrush" Color="{StaticResource WindowInnerBgColor}"/>
    <SolidColorBrush x:Key="TitleBgBrush" Color="{StaticResource TitleBgColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextPlaceholderBrush" Color="{StaticResource TextPlaceholderColor}"/>
    <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource InputBgColor}"/>
    <SolidColorBrush x:Key="InputTextBrush" Color="{StaticResource InputTextColor}"/>
    <SolidColorBrush x:Key="InputCaretBrush" Color="{StaticResource InputCaretColor}"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource InputBorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentTextBrush" Color="{StaticResource AccentTextColor}"/>
    <SolidColorBrush x:Key="ButtonBgBrush" Color="{StaticResource ButtonBgColor}"/>
    <SolidColorBrush x:Key="ButtonTextBrush" Color="{StaticResource ButtonTextColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="{StaticResource ScrollThumbColor}"/>
    <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="{StaticResource ScrollThumbHoverColor}"/>
    <SolidColorBrush x:Key="TabBgBrush" Color="{StaticResource TabBgColor}"/>
    <SolidColorBrush x:Key="TabActiveBgBrush" Color="{StaticResource TabActiveBgColor}"/>
    <SolidColorBrush x:Key="TabActiveTextBrush" Color="{StaticResource TabActiveTextColor}"/>
    <SolidColorBrush x:Key="TabInactiveTextBrush" Color="{StaticResource TabInactiveTextColor}"/>
    <SolidColorBrush x:Key="ItemBgBrush" Color="{StaticResource ItemBgColor}"/>
    <SolidColorBrush x:Key="ListBgBrush" Color="{StaticResource ListBgColor}"/>
    <SolidColorBrush x:Key="BorderBgBrush" Color="{StaticResource BorderBgColor}"/>
    <SolidColorBrush x:Key="SplitterBrush" Color="{StaticResource SplitterColor}"/>

    <!-- ScrollBar style -->
    <Style TargetType="ScrollBar" x:Key="DarkScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="False">
                            <Track.Thumb>
                                <Thumb BorderThickness="0" MinHeight="20">
                                    <Thumb.Style>
                                        <Style TargetType="Thumb">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="{DynamicResource ScrollThumbBrush}" CornerRadius="3" Margin="0,2"/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Thumb">
                                                                <Border Background="{DynamicResource ScrollThumbHoverBrush}" CornerRadius="3" Margin="0,2"/>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Thumb.Style>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>
</ResourceDictionary>
