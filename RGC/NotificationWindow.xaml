<Window x:Class="RGC.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" Height="60" Width="320"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False"
        Topmost="True" ResizeMode="NoResize"
        FontFamily="Segoe UI">
    <Grid>
        <Border Background="#313244" CornerRadius="12" Opacity="0.95">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="3" Color="#000" Opacity="0.4" BlurRadius="6"/>
            </Border.Effect>
        </Border>
        <Border Background="#313244" CornerRadius="12" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4"
                        Background="#89b4fa" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="MessageText" Grid.Column="1"
                           Text="Уведомление" Foreground="#cdd6f4"
                           FontSize="13" VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>
    </Grid>
</Window>
