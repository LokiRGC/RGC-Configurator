<Window x:Class="RGC.FtpBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:RGC"
        Title="FTP Browser" Width="1100" Height="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>

    <Border Background="#181825" CornerRadius="16" BorderThickness="1" BorderBrush="#313244">
        <Grid Margin="14,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="120"/>
            </Grid.RowDefinitions>

            <!-- ===== Top bar ===== -->
            <Border Grid.Row="0" Background="#1e1e2e" CornerRadius="10"
                    Padding="12,6" Margin="0,0,0,8" BorderThickness="1" BorderBrush="#2a2b3d">
                <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#313244" CornerRadius="6" Padding="10,4" Margin="0,0,8,0">
                            <TextBlock x:Name="BrowserTitle" FontSize="13" FontWeight="Bold" Foreground="#cdd6f4"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock x:Name="StatusText" Grid.Column="1" Foreground="#585b70" FontSize="11"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                        <Button x:Name="BackBtn" Grid.Column="2" Style="{StaticResource IconBtn}"
                                Content="←" Foreground="#89b4fa" FontSize="18"
                                ToolTip="Back to projects" Click="Back_Click"/>
                        <Button x:Name="SyncBtn" Grid.Column="3" Style="{StaticResource IconBtn}"
                                Content="🔄" Foreground="#f9e2af" FontSize="14"
                                ToolTip="Sync with local folder" Click="Sync_Click"
                                Visibility="Collapsed"/>
                        <Button x:Name="RefreshBtn" Grid.Column="4" Style="{StaticResource IconBtn}"
                                Content="↻" Foreground="#a6e3a1" FontSize="16"
                                ToolTip="Refresh" Click="Refresh_Click"/>
                        <Button x:Name="CloseBrowserBtn" Grid.Column="5" Style="{StaticResource IconBtn}"
                                Content="✕" Foreground="#585b70" FontSize="16"
                                ToolTip="Close" Click="Close_Click"/>
                </Grid>
            </Border>

            <!-- ===== Main area: Tree + Editor ===== -->
            <Grid Grid.Row="1" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ===== Left: Tree panel ===== -->
                <Border Grid.Column="0" BorderThickness="1" BorderBrush="#2a2b3d"
                        CornerRadius="10" Background="#1e1e2e">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#181825" CornerRadius="10,10,0,0"
                                Padding="12,8" BorderThickness="0,0,0,1" BorderBrush="#2a2b3d">
                            <Grid>
                                <TextBlock Text="📁  Files" Foreground="#a6adc8"
                                           FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock x:Name="FileCountText" Foreground="#585b70" FontSize="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <TreeView x:Name="FileTree" Grid.Row="1"
                                  Background="Transparent" BorderThickness="0" Foreground="#cdd6f4"
                                  TreeViewItem.Expanded="OnNodeExpanded"
                                  SelectedItemChanged="FileTree_SelectedItemChanged"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <TreeView.Resources>
                                <SolidColorBrush x:Key="TreeViewItem.TreeArrow.Static.Stroke">#585b70</SolidColorBrush>
                                <SolidColorBrush x:Key="TreeViewItem.TreeArrow.Static.Fill">Transparent</SolidColorBrush>
                                <SolidColorBrush x:Key="TreeViewItem.TreeArrow.MouseOver.Stroke">#89b4fa</SolidColorBrush>
                                <SolidColorBrush x:Key="TreeViewItem.TreeArrow.MouseOver.Fill">Transparent</SolidColorBrush>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#cdd6f4"/>
                                    <Setter Property="Padding" Value="4,3"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#252536"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#313244"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                <HierarchicalDataTemplate DataType="{x:Type local:FtpTreeNode}"
                                                          ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Margin="2,0,0,0">
                                        <TextBlock Text="{Binding Icon}" FontSize="13" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding Name}" FontSize="12"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </Grid>
                </Border>

                <!-- ===== Right: Editor panel ===== -->
                <Border Grid.Column="2" BorderThickness="1" BorderBrush="#2a2b3d"
                        CornerRadius="10" Background="#1e1e2e">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Editor toolbar -->
                        <Border Grid.Row="0" Background="#181825" CornerRadius="10,10,0,0"
                                Padding="8,5" BorderThickness="0,0,0,1" BorderBrush="#2a2b3d">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="DownloadBtn" Style="{StaticResource ToolBtn}"
                                            Background="#a6e3a1" Foreground="#1e1e2e"
                                            Content="⬇ Download" IsEnabled="False"
                                            Click="Download_Click"/>
                                    <Button x:Name="DeleteBtn" Style="{StaticResource ToolBtn}"
                                            Background="#f38ba8" Foreground="#1e1e2e"
                                            Content="🗑 Delete" IsEnabled="False"
                                            Click="Delete_Click"/>
                                    <Button x:Name="RenameBtn" Style="{StaticResource ToolBtn}"
                                            Background="#fab387" Foreground="#1e1e2e"
                                            Content="✏ Rename" IsEnabled="False"
                                            Click="Rename_Click"/>

                                    <Border Width="1" Height="18" Background="#2a2b3d" Margin="6,0,8,0"/>

                                    <Button x:Name="ValidateBtn" Style="{StaticResource ToolBtn}"
                                            Background="#cba6f7" Foreground="#1e1e2e"
                                            Content="✓ Validate" IsEnabled="False"
                                            Click="Validate_Click"/>

                                    <Button x:Name="UploadBtn" Style="{StaticResource ToolBtn}"
                                            Background="#89b4fa" Foreground="#1e1e2e"
                                            Content="💾 Apply Changes" IsEnabled="False"
                                            Click="Upload_Click"/>
                                </StackPanel>
                                <TextBlock x:Name="FileNameTab" Foreground="#585b70" FontSize="10"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,4,0" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>

                        <!-- Editor content -->
                        <Border x:Name="EditorContainer" Grid.Row="1" Margin="0" Background="#1e1e2e"
                                CornerRadius="0">
                            <TextBlock Text="Select a file to view and edit"
                                       Foreground="#585b70" FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <!-- File info bottom bar -->
                        <Border Grid.Row="2" Background="#181825"
                                Padding="12,5" BorderThickness="0,1,0,0" BorderBrush="#2a2b3d"
                                CornerRadius="0,0,10,10">
                            <Grid>
                                <TextBlock x:Name="FileInfoText" Foreground="#585b70"
                                           FontSize="10" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===== Console ===== -->
            <Border Grid.Row="2" BorderThickness="1" BorderBrush="#2a2b3d"
                    CornerRadius="10" Background="#11111b">
                <Grid Margin="6,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="6,2,6,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Width="6" Height="6" Fill="#89b4fa" Margin="0,0,8,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="0" Text="Console" Foreground="#585b70"
                                   FontSize="10" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="14,0,0,0"/>
                        <Button x:Name="ClearConsoleBtn" Grid.Column="2"
                                Content="✕ Clear" Height="22" Padding="8,0"
                                Background="#1e1e2e" Foreground="#585b70"
                                BorderThickness="1" BorderBrush="#2a2b3d"
                                Cursor="Hand" FontSize="9"
                                Click="ClearConsole_Click"/>
                    </Grid>

                    <TextBox x:Name="ConsoleBox" Grid.Row="1"
                             IsReadOnly="True" Background="Transparent"
                             Foreground="#a6adc8" FontSize="11"
                             BorderThickness="0"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" Padding="6,0"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
