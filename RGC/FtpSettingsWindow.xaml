<Window x:Class="RGC.FtpSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FTP Settings" Width="520"
        SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CaretBrush" Value="#89b4fa"/>
        </Style>
    </Window.Resources>

    <Border Background="#181825" CornerRadius="16" BorderThickness="1" BorderBrush="#313244">
        <StackPanel>
            <!-- Header bar -->
            <Border Height="4" Background="#89b4fa"/>

            <StackPanel Margin="28,20,28,24">
                <!-- Title -->
                <TextBlock x:Name="WinTitle" FontSize="18" FontWeight="Bold"
                           Foreground="#cdd6f4" Margin="0,0,0,16"/>

                <!-- Name -->
                <TextBlock x:Name="NameLabel" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="NameBox" Style="{StaticResource FieldBox}"/>

                <!-- Host -->
                <TextBlock x:Name="HostLabel" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="HostBox" Style="{StaticResource FieldBox}"/>

                <!-- Port -->
                <TextBlock x:Name="PortLabel" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="PortBox" Style="{StaticResource FieldBox}" Text="21"/>

                <!-- Username -->
                <TextBlock x:Name="UserLabel" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="UserBox" Style="{StaticResource FieldBox}"/>

                <!-- Password -->
                <TextBlock x:Name="PassLabel" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="PassBox" FontSize="13" Padding="10,8"
                             Background="#313244" Foreground="#cdd6f4"
                             BorderThickness="0" PasswordChar="●"/>

                <!-- Connect to FTP button -->
                <TextBlock x:Name="RemoteLabel" Style="{StaticResource FieldLabel}" Margin="0,16,0,0"/>
                <Button x:Name="ConnectFtpBtn" Height="42"
                        Background="#89b4fa" Foreground="#1e1e2e"
                        BorderThickness="0" Cursor="Hand"
                        FontSize="14" FontWeight="Bold"
                        Margin="0,4,0,0"
                        Click="ConnectFtp_Click"/>

                <!-- Local path -->
                <TextBlock x:Name="LocalLabel" Style="{StaticResource FieldLabel}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="LocalBox" Grid.Column="0" Style="{StaticResource FieldBox}"/>
                    <Button x:Name="BrowseBtn" Grid.Column="1" Height="34" Width="34"
                            Content="📂" Margin="6,0,0,0"
                            Background="#313244" Foreground="#cdd6f4"
                            BorderThickness="0" Cursor="Hand" FontSize="14"
                            Click="BrowseLocal_Click"/>
                </Grid>

                <!-- Buttons -->
                <Grid Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="DeleteBtn" Grid.Column="0"
                            Height="36" Padding="16,0" MinWidth="80"
                            Background="#f38ba8" Foreground="#1e1e2e"
                            BorderThickness="0" Cursor="Hand"
                            FontSize="13" FontWeight="SemiBold"
                            Click="Delete_Click"/>
                    <Button x:Name="CancelBtn" Grid.Column="2"
                            Height="36" Padding="16,0" MinWidth="70"
                            Background="Transparent" Foreground="#6c708b"
                            BorderThickness="0" Cursor="Hand"
                            FontSize="13"
                            IsCancel="True"
                            Click="Cancel_Click"/>
                    <Button x:Name="SaveBtn" Grid.Column="4"
                            Height="36" Padding="20,0" MinWidth="100"
                            Background="#89b4fa" Foreground="#1e1e2e"
                            BorderThickness="0" Cursor="Hand"
                            FontSize="13" FontWeight="Bold"
                            IsDefault="True"
                            Click="Save_Click"/>
                </Grid>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
