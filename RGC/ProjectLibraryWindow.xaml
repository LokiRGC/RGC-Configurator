<Window x:Class="RGC.ProjectLibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RGC Configurator"
        Width="1100" Height="720"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        MouseDown="Window_MouseDown"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="AddBtn" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#89b4fa"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Content" Value="＋"/>
        </Style>
    </Window.Resources>

    <Border Background="#181825" CornerRadius="16" BorderThickness="1" BorderBrush="#313244">
        <Grid Margin="28,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="4,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="LibTitle" Grid.Column="0"
                           FontSize="22" FontWeight="Bold" Foreground="#cdd6f4"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="NewProjectBtn" Height="34"
                            Background="#89b4fa" Foreground="#1e1e2e"
                            BorderThickness="0" Cursor="Hand"
                            FontSize="13" FontWeight="SemiBold"
                            Padding="16,0" VerticalAlignment="Center"
                            Click="NewProject_Click"/>
                </StackPanel>
                <Button x:Name="CloseBtn" Grid.Column="2"
                        Content="✕" Width="32" Height="32"
                        Background="Transparent" Foreground="#585b70"
                        BorderThickness="0" Cursor="Hand" FontSize="16"
                        Margin="12,0,0,0" VerticalAlignment="Center"
                        Click="Close_Click"/>
            </Grid>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          BorderThickness="0" Padding="0,0,4,0">
                <StackPanel>
                    <!-- Local Projects -->
                    <StackPanel Margin="0,0,0,8">
                        <Grid Margin="0,0,0,4">
                            <TextBlock x:Name="LocalHeader" Style="{StaticResource SectionTitle}"/>
                        </Grid>
                        <WrapPanel x:Name="LocalPanel"/>
                    </StackPanel>

                    <Border Height="1" Background="#313244" Margin="0,4,0,12"/>

                    <!-- FTP Projects -->
                    <StackPanel Margin="0,0,0,8">
                        <Grid Margin="0,0,0,4">
                            <TextBlock x:Name="FtpHeader" Style="{StaticResource SectionTitle}"
                                       HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <Button x:Name="AddFtpBtn" Style="{StaticResource AddBtn}"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Click="AddFtp_Click"/>
                        </Grid>
                        <WrapPanel x:Name="FtpPanel"/>
                    </StackPanel>

                    <Border Height="1" Background="#313244" Margin="0,4,0,12"/>

                    <!-- Tools -->
                    <StackPanel Margin="0,0,0,8">
                        <Grid Margin="0,0,0,4">
                            <TextBlock x:Name="ToolsHeader" Style="{StaticResource SectionTitle}"/>
                        </Grid>
                        <WrapPanel x:Name="ToolsPanel"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
