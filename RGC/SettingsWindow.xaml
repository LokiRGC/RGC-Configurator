<Window x:Class="RGC.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" Height="500" Width="440"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" FontFamily="Segoe UI"
        MouseDown="Window_MouseDown"
        Activated="Window_Activated">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="SectionTitle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>
        <Style TargetType="Border" x:Key="Card">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
        </Style>
    </Window.Resources>
    <Border Background="{DynamicResource WindowBgBrush}" CornerRadius="12" Padding="24,20">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock x:Name="WinTitle" Text="Настройки приложения" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,16"/>

                <TextBlock x:Name="SectGeneral" Text="Общие" Style="{StaticResource SectionTitle}"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <CheckBox x:Name="ConfirmExitCheck" Content="Подтверждать выход из приложения"
                                  Foreground="{DynamicResource TextBrush}" FontSize="13" Margin="0,0,0,10"
                                  Checked="ConfirmExit_Changed" Unchecked="ConfirmExit_Changed"/>
                        <CheckBox x:Name="MinimizeTrayCheck" Content="Сворачивать в трей вместо закрытия"
                                  Foreground="{DynamicResource TextBrush}" FontSize="13"
                                  Checked="MinimizeTray_Changed" Unchecked="MinimizeTray_Changed"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="SectLang" Text="Язык интерфейса" Style="{StaticResource SectionTitle}"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <RadioButton x:Name="LangRu" Content="Русский" GroupName="Language"
                                     Foreground="{DynamicResource TextBrush}" FontSize="13" Margin="0,0,0,6"
                                     Checked="Lang_Changed"/>
                        <RadioButton x:Name="LangEn" Content="English" GroupName="Language"
                                     Foreground="{DynamicResource TextBrush}" FontSize="13"
                                     Checked="Lang_Changed"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="SectNotif" Text="Уведомления" Style="{StaticResource SectionTitle}"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <CheckBox x:Name="NotifSoundCheck" Content="Звук уведомлений"
                                  Foreground="{DynamicResource TextBrush}" FontSize="13" Margin="0,0,0,10"
                                  Checked="NotifSound_Changed" Unchecked="NotifSound_Changed"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="NotifDurationLabel" Text="Длительность показа" Foreground="{DynamicResource TextBrush}" FontSize="13" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Slider x:Name="DurationSlider" Minimum="1" Maximum="10" Width="100"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ValueChanged="Duration_Changed"/>
                                <TextBlock x:Name="DurationLabel" Text="3 сек" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center" Width="40"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="SectAppearance" Text="Оформление" Style="{StaticResource SectionTitle}"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <CheckBox x:Name="AutoStartCheck" Content="Открывать при загрузке Windows"
                                  Foreground="{DynamicResource TextBrush}" FontSize="13" Margin="0,0,0,10"
                                  Checked="AutoStart_Changed" Unchecked="AutoStart_Changed"/>
                        <RadioButton x:Name="DarkThemeRadio" Content="Тёмная тема" GroupName="Theme"
                                     Foreground="{DynamicResource TextBrush}" FontSize="13" Margin="0,0,0,6"
                                     Checked="Theme_Changed"/>
                        <RadioButton x:Name="LightThemeRadio" Content="Светлая тема" GroupName="Theme"
                                     Foreground="{DynamicResource TextBrush}" FontSize="13"
                                     Checked="Theme_Changed"/>
                    </StackPanel>
                </Border>

                <Button x:Name="CloseBtn" Content="✕ Закрыть" Click="Close_Click"
                        Background="{DynamicResource ButtonBgBrush}" Foreground="{DynamicResource ButtonTextBrush}" BorderThickness="0"
                        Padding="12,6" FontSize="12" Cursor="Hand" Margin="0,20,0,0"
                        HorizontalAlignment="Center" Width="120"/>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
