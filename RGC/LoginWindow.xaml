<Window x:Class="RGC.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RGC" Height="520" Width="420"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style TargetType="TextBox" x:Key="InputStyle">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="#89b4fa"/>
        </Style>
        <Style TargetType="PasswordBox" x:Key="PasswordInputStyle">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Background" Value="#89b4fa"/>
            <Setter Property="Foreground" Value="#1e1e2e"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="SecondaryBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#89b4fa"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#181825" CornerRadius="16" Margin="15" MouseDown="Window_MouseDown">
        <Grid Margin="30,25">
            <Button Content="✕" Width="28" Height="28" Background="Transparent" Foreground="#6c7086"
                    BorderThickness="0" Cursor="Hand" FontSize="14"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,-8,-8,0" Click="Close_Click"/>
            <TextBlock Text="v1.0.0" FontSize="11" Foreground="#585b70" 
                       HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,5"/>
            <StackPanel VerticalAlignment="Center">
                <Border Width="56" Height="56" CornerRadius="14" Background="#313244" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <Image Source="pack://application:,,,/login_logo.png" Width="32" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Добро пожаловать" FontSize="24" FontWeight="Bold" Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Войдите или создайте аккаунт" FontSize="13" Foreground="#6c7086" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="RAGNAROK COMMUNITY" FontSize="11" Foreground="#89b4fa" HorizontalAlignment="Center" Margin="0,0,0,25" FontWeight="SemiBold"/>

                <TextBlock Text="Имя пользователя" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="UsernameBox" Style="{StaticResource InputStyle}" Margin="0,0,0,14"/>

                <TextBlock Text="Пароль" Style="{StaticResource LabelStyle}"/>
                <PasswordBox x:Name="PasswordBox" Style="{StaticResource PasswordInputStyle}" Margin="0,0,0,12"/>

                <CheckBox x:Name="RememberCheckbox" Content="Запомнить аккаунт" 
                          Foreground="#a6adc8" FontSize="12" Margin="0,0,0,16"
                          Background="Transparent"/>

                <Button Content="Войти" Style="{StaticResource PrimaryBtn}" Click="Login_Click" Margin="0,0,0,8"/>
                <Button Content="Зарегистрироваться" Style="{StaticResource SecondaryBtn}" Click="Register_Click" Margin="0,0,0,12"/>

                <TextBlock x:Name="StatusText" Text="" Foreground="#6c7086" HorizontalAlignment="Center" TextWrapping="Wrap" FontSize="12"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
